<Window x:Class="RefineLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="412" Height="142"
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="{x:Null}"
        AllowsTransparency="True"
        UseLayoutRounding="True">

    <!-- Root grid owns the entrance animation -->
    <Grid x:Name="RootGrid" Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="0.94" ScaleY="0.94"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <!-- Fade in: cubic ease-out, 200ms -->
                        <DoubleAnimationUsingKeyFrames
                            Storyboard.TargetName="RootGrid"
                            Storyboard.TargetProperty="Opacity">
                            <SplineDoubleKeyFrame Value="1" KeyTime="0:0:0.2"
                                                  KeySpline="0.1,0.9,0.2,1"/>
                        </DoubleAnimationUsingKeyFrames>
                        <!-- Scale X: quintic ease-out, 300ms -->
                        <DoubleAnimationUsingKeyFrames
                            Storyboard.TargetName="RootScale"
                            Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame Value="1" KeyTime="0:0:0.3"
                                                  KeySpline="0.1,0.9,0.2,1"/>
                        </DoubleAnimationUsingKeyFrames>
                        <!-- Scale Y: quintic ease-out, 300ms -->
                        <DoubleAnimationUsingKeyFrames
                            Storyboard.TargetName="RootScale"
                            Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame Value="1" KeyTime="0:0:0.3"
                                                  KeySpline="0.1,0.9,0.2,1"/>
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <!-- Outer surface — shadow lives here so it renders outside the clip -->
        <Border Margin="16" CornerRadius="14" Background="#1C1C1C">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.55"
                                  BlurRadius="28" ShadowDepth="0"/>
            </Border.Effect>

            <!-- Inner glass rim — subtle white stroke, 1px inside the surface -->
            <Border CornerRadius="13" BorderBrush="#1EFFFFFF" BorderThickness="1">
                <Grid Margin="24,18,24,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="3"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Refine"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#C7C7C7"
                               FontFamily="Segoe UI"/>

                    <TextBlock Grid.Row="2"
                               x:Name="StatusText"
                               Text="Starting…"
                               FontSize="12"
                               Foreground="#888888"
                               FontFamily="Segoe UI"/>

                    <ProgressBar Grid.Row="4"
                                 x:Name="UpdateProgress"
                                 Height="3"
                                 Minimum="0" Maximum="100" Value="0"
                                 Visibility="Collapsed"
                                 Background="#2A2A2A"
                                 Foreground="#C7C7C7"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
