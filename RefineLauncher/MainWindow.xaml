<Window x:Class="RefineLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="110"
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        AllowsTransparency="True">

    <Border Background="#1E1E1E" CornerRadius="8"
            BorderBrush="#333333" BorderThickness="1">
        <Grid Margin="24,18,24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="3"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Refine"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#C7C7C7"
                       FontFamily="Segoe UI"/>

            <TextBlock Grid.Row="2"
                       x:Name="StatusText"
                       Text="Starting…"
                       FontSize="12"
                       Foreground="#888888"
                       FontFamily="Segoe UI"/>

            <ProgressBar Grid.Row="4"
                         x:Name="UpdateProgress"
                         Height="3"
                         Minimum="0" Maximum="100" Value="0"
                         Visibility="Collapsed"
                         Background="#333333"
                         Foreground="#C7C7C7"/>
        </Grid>
    </Border>
</Window>
